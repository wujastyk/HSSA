% See 
%\href{https://tex.stackexchange.com/questions/127222/fonts-for-polytonic-greek}{Stackexchange
% about Greek fonts}.
%
%\bigskip
% \subsection{Local generic author-facing macros}
% \begin{macro}{\bce, \ce, \BCE, \CE}
%    \begin{macrocode}
\DeclareRobustCommand\bce{\textsc{bce}} % I took out the final \xspace 
									   % because it's behaviour is hard to predict - DW
\DeclareRobustCommand\ce{\textsc{ce}} % ditto.
\let\BC\bce \let\BCE\bce \let\AD\ce \let\CE\ce
%    \end{macrocode}
% \end{macro}

% \subsection{Math mode with Unicode fonts}
%
% \begin{macro}{unicode-math}
% Load the \verb|unicode-math| package and use the Asana font (which is 
% a type of Palatino).  
% An alternative would be to
% use the \verb|mathspec| package which can use the 
% TeX Gyre Pagella Math, providing a slightly more uniform font
% situation for HSSA documents.  See the mathspec manual, section 2, 
% for discussion.
%
% The code would then look like this:\\
% \verb|\Requirepackage[math]{mathspec}|
% \verb|\setmathfont(Digits,Latin,Greek)[Numbers={Lining,Proportional}]|
% \verb|{TeX Gyre Pagella Math}|
%    \begin{macrocode}
\RequirePackage{unicode-math} % must load after amsmath; see manual ch. 3
% must also load after hssa-biblatex.sty to avoid some very technical
% char-number overrun errors issued because of \verb|\resetMathstrut@|.
%\setmathfont{TeX Gyre Pagella Math}[Numbers=OldStyle]  
% doesn't have oldstyle numbers in mathmode.
\setmathfont{Asana Math}[Numbers=OldStyle] % works well
%    \end{macrocode}
% \end{macro}


