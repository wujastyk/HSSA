%
% \subsubsection{Greek font}
%    \begin{macrocode}% Greek
\newfontfamily\greekfont[Script=Greek,
%    Ligatures=TeX,
    AutoFakeBold=1.5,
    Scale=MatchUppercase]
{GFS Porson}
%{GFS Didot}
\fi % end of xetex/luatex else
