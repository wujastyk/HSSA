% \section{\texttt{hssa.sty}: HSSA main style file}
% This code is in the file \verb|hssa.sty|.
% Style file for the HSSA journal.\footnote{See 
%\url{http://tug.org/pracjourn/2005-3/asknelly/} 
% for a nice statement of the 
% difference between .cls and .sty files.}  Here in hssa.sty, I'm keeping
% the code that is not part of the core of HSSA's design, including calls to other style
% files that might or might not be included for different articles.
%
%\subsection{Load basic macros for reledmac}
%  \begin{environment}{hssa-reledmac}
% We load \verb|reledmac.sty| with some parameters set in the file 
% \verb|hssa-reledmac.sty|.  This redefines \verb|\footnote| to produce
% double-column notes.  Also, it makes the macros of \verb|reledmac|
% available for making critical editions. 
%
%    \begin{macrocode}
\usepackage{hssa-reledmac} % journal home style, two-col footnotes
%    \end{macrocode}
% 
% For some documents without the need for critical edition features, 
% it may be enough to 
% use \verb|dblfnote.sty| instead.
%  \end{environment}
%
% Note: we don't load  \verb"hssa-biblatex" here because it is 
% already loaded in \verb"hssa.cls"; it's a permanent feature of HSSA. 
%
% \bigskip
%\subsection{Languages and fonts, Polyglossia-style}
%
% \subsubsection{British English, Greek, Sanskrit}
%    \begin{macrocode}
\ifLuaTeX
\else % XeLaTeX with Polyglossia
\setdefaultlanguage[variant=british]{english}
%\setotherlanguage{japanese} % still experimental in Polyglossia
\setotherlanguage{greek}
\setotherlanguage{sanskrit}
%\setotherlanguage{arabic}
\fi % xetex/luatex
%    \end{macrocode}
%
% \subsubsection{\TeX\ Gyre Pagella, the default roman font for HSSA}
%    \begin{macrocode}
\ifLuaTeX
% put something here when you know what.
\else 
% XeLaTeX with Polyglossia
\setmainfont[Ligatures=TeX,
  Numbers=OldStyle]{TeX Gyre Pagella}
\fi
%\setmainfont[Scale=1.05]{Alegreya} % quite nice; superscripts not smaller
%\setmainfont{Libertinus Serif} % looks good; does math
%    \end{macrocode}
%
% \subsubsection{Sanskrit input in Devanagari script}
%    \begin{macrocode}
\ifLuaTeX
% Define the fonts
% The [*devanagari] modifier tells babel to automatically switch to this 
% font whenever the Sanskrit language is invoked. 
% Crucially for LuaLaTeX, Harfbuzz must be explicitly called here.
\babelfont{rm}{TeX Gyre Pagella} % e.g., GFS Didot or Times
\babelfont[*devanagari]{rm}[Renderer=Harfbuzz, 
   Script=Devanagari]
  {Sanskrit 2020} % e.g., Murty Sanskrit
%
% Author-facing macros
% For inline Devanagari text
\newcommand{\textsanskrit}[1]{\foreignlanguage{sanskrit}{#1}}
\newcommand{\san}[1]{\textsanskrit{#1}} % convenient shorthand
\newcommand{\dev}[1]{\textsanskrit{#1}} % convenient shorthand
%
%
\else % XeTeX up to the \verb|\fi| at about line 120
\newfontfamily\sanskritfont[Renderer=Harfbuzz,
  Script=Devanagari,
  %Mapping=RomDev,
  FakeStretch=1.08, % improves Sanskrit 2003
  AutoFakeBold=1.5,
  ]
{Sanskrit 2020}
% {Sanskrit 2003} % Now superseded by 2020
%  {Murty Sanskrit}
%
\let\dn\sanskritfont %for legacy Velthuis-encoded documents
%    \end{macrocode}
%
% \subsubsection{Sanskrit input in IAST script, output in Devanagari}
%    \begin{macrocode}% Sanskrit input in IAST
\newfontfamily\devanagarifont[Renderer=Harfbuzz,
Script=Devanagari,
Language=Sanskrit,
Mapping=RomDev,
FakeStretch=1.08, % improves Sanskrit 2003
AutoFakeBold=1,
]
%{Tiro Devanagari Sanskrit} %autofakebold 2.0
{Sanskrit 2020} 
\newcommand{\dev}[1]{{\devanagarifont#1}}
%\newcommand{\dev}[1]{\textdevanagari{#1}}
\newcommand{\largesloka}[1]{{\raggedright \devanagarifont\large #1\par}}
%    \end{macrocode}
%
% \subsubsection{Chinese}
%    \begin{macrocode}
\newfontfamily\cjk[Script=CJK,
    Ligatures=TeX,
    Scale=MatchLowercase]
%{IPAexMincho} % missing 說
%{TakaoPGothic}
%{Noto Serif CJK JP}
{Yu Mincho} % Make sure this font is installed.
%
%    \end{macrocode}
%
